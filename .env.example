# Copy this file to ".env" (same folder) and fill in your real values.
# Never commit the real .env file anywhere public — it contains secrets.

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# A random secret Flask uses to cryptographically sign login session
# cookies. Generate one yourself, e.g. by running this once:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# and pasting the result below. Keep it secret and don't change it
# after going live, or everyone will be logged out.
FLASK_SECRET_KEY=replace-this-with-a-long-random-string
